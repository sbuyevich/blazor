@page "/"
<PageTitle>Student Projects</PageTitle>

<h1>Student Projects</h1>

<p>This app uses a minimal custom cookie-auth flow on top of the seeded SQLite user store.</p>

@if (!string.IsNullOrWhiteSpace(CurrentSchoolName))
{
    <p>Current school: <strong>@CurrentSchoolName</strong></p>
}

<AuthorizeView>
    <Authorized>
        <p>You are signed in as <strong>@context.User.Identity?.Name</strong>.</p>
        <p><a href="projects">Open the protected projects area</a>.</p>
    </Authorized>
    <NotAuthorized>
        <p><a href="login">Sign in</a> with the seeded credentials, or <a href="signup">create a new account</a>.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    [SupplyParameterFromQuery(Name = "school")]
    private string? SchoolQuery { get; set; }

    [SupplyParameterFromQuery(Name = "shool")]
    private string? ShoolQuery { get; set; }

    private string? CurrentSchoolName { get; set; }

    protected override void OnParametersSet()
    {
        CurrentSchoolName = SchoolQuery ?? ShoolQuery;
    }
}
