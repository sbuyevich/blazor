@page "/admin/students"
@attribute [Authorize(Policy = AuthenticationConstants.AdminPolicy)]
@using Microsoft.EntityFrameworkCore
@using student_projects.Data

@inject IDbContextFactory<ApplicationDbContext> DbContextFactory

<PageTitle>Admin Students</PageTitle>

<h1>Students</h1>

<div class="mb-3">
    <label class="form-label" for="student-search">Search students</label>
    <input id="student-search"
           class="form-control"
           @bind="_searchText"
           @bind:event="oninput"
           placeholder="Search by username, class, or school" />
</div>

@if (_isLoading)
{
    <p>Loading students...</p>
}
else if (FilteredStudents.Count == 0)
{
    <p>No students found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th scope="col">Id</th>
                    <th scope="col">UserName</th>
                    <th scope="col">Class</th>
                    <th scope="col">School</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in FilteredStudents)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td>@student.UserName</td>
                        <td>@student.ClassName</td>
                        <td>@student.SchoolName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private readonly List<StudentGridRow> _students = [];
    private string? _searchText;
    private bool _isLoading = true;

    private IReadOnlyList<StudentGridRow> FilteredStudents
    {
        get
        {
            var searchText = _searchText?.Trim();
            if (string.IsNullOrWhiteSpace(searchText))
            {
                return _students;
            }

            return _students
                .Where(student =>
                    ContainsSearchText(student.UserName, searchText) ||
                    ContainsSearchText(student.ClassName, searchText) ||
                    ContainsSearchText(student.SchoolName, searchText))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await using var dbContext = await DbContextFactory.CreateDbContextAsync();
        var students = await dbContext.Students
            .AsNoTracking()
            .Include(student => student.Class)
            .ThenInclude(schoolClass => schoolClass!.School)
            .OrderBy(student => student.UserName)
            .Select(student => new StudentGridRow(
                student.Id,
                student.UserName,
                student.Class == null ? "" : student.Class.Name,
                student.Class == null ? "" : student.Class.School.Name))
            .ToListAsync();

        _students.AddRange(students);
        _isLoading = false;
    }

    private static bool ContainsSearchText(string value, string searchText)
    {
        return value.Contains(searchText, StringComparison.OrdinalIgnoreCase);
    }

    private sealed record StudentGridRow(int Id, string UserName, string ClassName, string SchoolName);
}
