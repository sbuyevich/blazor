@page "/students"

<PageTitle>Students</PageTitle>

<ClassContextView>
    <ChildContent Context="currentClass">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h4">Students</MudText>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Student grid for @currentClass.SchoolName - @currentClass.ClassName will be implemented in the teacher student grid task.
            </MudAlert>
        </MudStack>
    </ChildContent>
</ClassContextView>
