@rendermode InteractiveServer
@implements IDisposable
@inject ILocalStorageService LocalStorage
@inject ILoginStateService LoginStateService

<MudStack Spacing="0" Class="pa-3">
    <MudText Typo="Typo.subtitle1" Class="px-2 pb-2">Navigation</MudText>

    <MudNavMenu Dense="true" Rounded="true">
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
        <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
        <MudNavLink Href="/register" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>

        @if (IsTeacher)
        {
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Color="Color.Secondary" Class="px-4">Teacher</MudText>
            <MudNavLink Href="/students" Icon="@Icons.Material.Filled.Groups">Students</MudNavLink>
        }
    </MudNavMenu>
</MudStack>

@code {
    private const string LoginStateKey = "my-class.loginState";

    private bool IsTeacher => LoginStateService.Current?.IsTeacher == true;

    protected override void OnInitialized()
    {
        LoginStateService.Changed += OnLoginStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var state = await LocalStorage.GetAsync<LoginState>(LoginStateKey);
        LoginStateService.Set(state);
    }

    private void OnLoginStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LoginStateService.Changed -= OnLoginStateChanged;
    }
}
