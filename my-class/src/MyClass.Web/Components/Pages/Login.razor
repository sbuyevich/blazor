@page "/"
@page "/login"
@rendermode InteractiveServer
@inject ISessionStorageService SessionStorage
@inject ILoginStateService LoginStateService
@inject IClassContextService ClassContextService
@inject NavigationManager Navigation

<PageTitle>My Class</PageTitle>

<ClassContextView>
    <ChildContent Context="currentClass">
        <div class="login-shell">
            <MudPaper Class="login-panel pa-5" Elevation="2">
                <LoginForm CurrentClass="currentClass"
                           Succeeded="HandleSucceededAsync"
                           RegisterRequested="GoToRegister" />
            </MudPaper>
        </div>
    </ChildContent>
</ClassContextView>

@code {

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var state = LoginStateService.Current ?? await SessionStorage.GetLoginStateAsync();

        if (state is null)
        {
            return;
        }

        LoginStateService.Set(state);
        Navigation.NavigateTo(GetClassPath("/home", state.ClassCode));
    }

    private Task HandleSucceededAsync(LoginState state)
    {
        Navigation.NavigateTo(GetClassPath("/home", state.ClassCode));

        return Task.CompletedTask;
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo(GetClassPath("/register"));
    }

    private string GetClassPath(string path, string? classCode = null)
    {
        return ClassContextService.GetPathWithClassCode(
            path,
            classCode ?? ClassContextService.GetClassCodeFromUri(Navigation.Uri));
    }
}
