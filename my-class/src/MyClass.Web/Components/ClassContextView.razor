@implements IDisposable
@inject IClassContextService ClassContextService
@inject NavigationManager Navigation

@if (_result is null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <MudText Typo="Typo.body2">Loading class...</MudText>
    </MudStack>
}
else if (!_result.IsLoaded)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_result.Message</MudAlert>
}
else if (ChildContent is not null)
{
    @ChildContent(_result.CurrentClass!)
}
