@rendermode InteractiveServer
@implements IAsyncDisposable
@inject ILoginStateService LoginStateService
@inject ISessionStorageService SessionStorage
@inject IQuizAnswerService QuizAnswerService
@inject IOptions<QuizOptions> QuizOptions
@inject NavigationManager Navigation

@if (_isLoading)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <MudText Typo="Typo.body2">Loading quiz answer...</MudText>
    </MudStack>
}
else
{
    <MudStack Spacing="3" Class="quiz-answer-shell">
        <div>
            <MudText Typo="Typo.h4">Answer</MudText>
            <MudText Typo="Typo.h6">Select correct answer number</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@StatusMessage</MudText>
        </div>

        @if (AnswerChoices.Count > 0)
        {
            <MudGrid Spacing="20">
                @foreach (var answer in AnswerChoices)
                {
                    <MudItem>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   FullWidth="true"
                                   Class="quiz-answer-button"
                                   Disabled="DisableAnswerButtons"
                                   OnClick="() => SubmitAnswerAsync(answer)">
                            @answer
                        </MudButton>
                    </MudItem>
                }
            </MudGrid>
        }
        else if (_stateResult?.State?.HasInProgressAnswer == true)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                No answer choices are available for this question.
            </MudAlert>
        }
    </MudStack>
}
