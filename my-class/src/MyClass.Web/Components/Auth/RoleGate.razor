@rendermode InteractiveServer
@implements IDisposable
@inject ISessionStorageService SessionStorage
@inject ILoginStateService LoginStateService

@if (!_loadedLoginState)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <MudText Typo="Typo.body2">Checking access...</MudText>
    </MudStack>
}
else if (LoginStateService.Current is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
        Sign in to continue.
    </MudAlert>
}
else if (RequireTeacher && LoginStateService.Current.IsTeacher)
{
    @ChildContent
}
else if (!RequireTeacher && !LoginStateService.Current.IsTeacher)
{
    @ChildContent
}
else
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
        @DeniedMessage
    </MudAlert>
}
